.terraformrc
terraform.rc

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Application
node_modules/
npm-debug.log
.env
.env.local
dist/
build/

# OS
*.log
.DS_Store
Thumbs.db
EOF